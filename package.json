{
  "name": "mcp-server-stripe",
  "version": "1.0.0",
  "description": "Production-quality MCP server for the Stripe API v1 — 20 tools covering Customers, PaymentIntents, Subscriptions, Invoices, Products, Prices, Charges, and Refunds",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-server-stripe": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:http": "MCP_TRANSPORT=http node dist/index.js",
    "dev": "tsx src/index.ts"
  },
  "keywords": ["mcp", "stripe", "payments", "billing", "model-context-protocol"],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.5.0"
  }
}
